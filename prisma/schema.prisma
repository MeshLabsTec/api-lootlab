generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String?
  email     String?   @unique
  password  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role      Role?     @default(USER)
  posts     Post[]    @relation("UserPosts")
  comments  Comment[] @relation("UserComments")
  likes     Like[]    @relation("UserLikes")
}

model Post {
  id                String            @id @default(uuid())
  title             String            @db.VarChar(255)
  category          String            @db.VarChar(255)
  market_link       String?           @db.VarChar(255)
  score             Int?              @default(0)
  investment        String?           @db.VarChar(255)
  token             String?           @db.VarChar(255)
  network           String?           @db.VarChar(255)
  comment_author    String?           @db.VarChar(5000)
  slug              String            @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  authorId          String?
  launchInfoId      String?
  projectFeaturesId String?
  linkId            String?
  comments          Comment[]         @relation("PostComments")
  likes             Like[]            @relation("PostLikes")
  links             Link[]            @relation("PostLinks")
  partnerships      Partnership[]     @relation("PostPartnerships")
  ProjectFeatures   ProjectFeatures[]
  launchInfo        LaunchInfo?
  Image             Image[]
  genres            Genre[]           @relation("PostGenres")
  author            User?             @relation("UserPosts", fields: [authorId], references: [id])
}

model Genre {
  id    String  @id @default(uuid())
  name  String? @unique
  posts Post[]  @relation("PostGenres")
}

model ProjectFeatures {
  id        String   @id @default(uuid())
  title     String?  @db.VarChar(255)
  isFeature Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Link {
  id        String    @id @default(uuid())
  postId    String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  post      Post?     @relation("PostLinks", fields: [postId], references: [id], onDelete: Cascade)
}

model LaunchInfo {
  id            String   @id @default(uuid())
  launchDate    String?  @db.VarChar(255)
  marketCap     Float?
  currentSupply String?  @db.VarChar(255)
  totalSupply   Float?
  privateSale   Float?
  publicSale    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  postId        String?  @unique
  post          Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Partnership {
  id        String   @id @default(uuid())
  type      String?  @db.VarChar(255)
  link_url  String?  @db.VarChar(255)
  post      Post?    @relation("PostPartnerships", fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Image {
  id        String   @id @default(uuid())
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(uuid())
  content   String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  post      Post?     @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  user      User?     @relation("UserComments", fields: [userId], references: [id])
  userId    String?
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  post      Post?    @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  user      User?    @relation("UserLikes", fields: [userId], references: [id])
  userId    String?
}

enum Role {
  ADMIN
  WRITER
  USER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
